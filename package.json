  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "start": "node dist/main.js",
    "dev": "clear; nodemon --watch 'src/**/*.ts' --exec ts-node src/app.ts",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:generate": "prisma generate",
    "prisma:seed": "ts-node prisma/seed.ts",
    "test:unit": "jest test/unit/*.ts -c ./jest.config.unit.js",
    "test:setupDB": "prisma migrate deploy && prisma generate",
    "test:integration": "dotenv -e .env.test -- sh -c 'npm run test:setupDB && jest test/integration/*.test.ts -c ./jest.config.integration.js --runInBand'",
    "test:api": "dotenv -e .env.test -- sh -c 'npm run test:setupDB && jest -c ./jest.config.api.js --detectOpenHandles --runInBand'"
  }
