Cookie: access-token={{accessToken}}; refresh-token={{refrshToken}}

###
POST {{baseUrl}}/api/auth/refresh
Cookie: refresh-token={{refrshToken}}
###
GET {{baseUrl}}/api/auth/refresh/view
Cookie: access-token={{accessToken}}; refresh-token={{refrshToken}}


########################################################################
#                                                  관리자 Auth 기능
######################################################################## 
### 관리자: 사용자 1명 가입상태 변경, residentId 사용
PATCH {{baseUrl}}/api/auth/residents/5a71956c-df42-4a4d-8c66-434d703cf12b/status
Cookie: access-token={{accessToken}}
Content-Type: application/json

{
  "status": "APPROVED"
}

### 관리자: 사용자 일괄 가입상태 변경
### 명부 only 입주자는 제외 (isRegistered = false) 
PATCH {{baseUrl}}/api/auth/residents/status
Cookie: access-token={{accessToken}}
Content-Type: application/json

{
  "status": "APPROVED"
}

########################################################################
#                                                최고관리자 Auth 기능
######################################################################## 
### 관리자 목록 조회: 개발용 부가 기능
GET {{baseUrl}}/api/auth/admins
Cookie: access-token={{accessToken}}
### 아파트 목록 조회: 개발용 부가 기능
GET {{baseUrl}}/api/auth/apartments
Cookie: access-token={{accessToken}}

# 아래의 가입승인 --> 모두 가입상태 변경으로 작성 (APPROVED, REJECTED 가능)
### 최고관리자: 관리자 1명 가입상태 변경
PATCH {{baseUrl}}/api/auth/admins/fd4cc731-8f71-4b86-ae85-f53ae4e31f47/status
Cookie: access-token={{accessToken}}
Content-Type: application/json

{
  "status": "APPROVED"
}

### 최고관리자: 관리자 일괄 가입상태 변경
PATCH {{baseUrl}}/api/auth/admins/status
Content-Type: application/json

{
  "status": "APPROVED"
}

