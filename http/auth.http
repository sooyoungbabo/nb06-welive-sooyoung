@baseUrl = http://localhost:3000

### 회원가입: 사용자
POST {{baseUrl}}/auth/signup
Content-Type: application/json

{
  "username": "bawoo",
  "password": "password0!",
  "contact": "010-9498-9528",
  "name": "가슴아픈바우",
  "email": "bawoo@test.com",
  "role": "USER",
  "apartmentName": "힐리아파트",
  "apartmentDong": "101",
  "apartmentHo": "101"
}
### 회원가입: 관리자 - 관리자/아파트/보드 생성
POST {{baseUrl}}/auth/signup/admin
Content-Type: application/json

{
  "username": "hillie",
  "password": "password0!",
  "contact": "010-1111-1111",
  "name": "보고싶은힐리",
  "email": "hillie@test.com",
  "description": "질서, 정리정돈, 청결 등 관리상태가 완벽한 아파트",
  "startComplexNumber": 1,
  "endComplexNumber": 5,
  "startDongNumber": 1,
  "endDongNumber": 10,
  "startFloorNumber": 1,
  "endFloorNumber": 25,
  "startHoNumber": 1,
  "endHoNumber": 10,
  "role": "ADMIN",
  "apartmentName": "힐리아파트",
  "apartmentAddress": "서울시 성북구 화랑로 277",
  "apartmentManagementNumber": "02-111-1111"
}

### 회원가입: 최고관리자
POST {{baseUrl}}/auth/signup/super-admin
Content-Type: application/json

{
  "username": "hillie1",
  "password": "password0!",
  "contact": "010-9999-9999",
  "name": "최고관리자",
  "email": "hillie1@test.com",
  "role": "SUPER_ADMIN",
  "joinStatus": "APPROVED"
}




